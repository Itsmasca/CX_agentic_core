# Credenciales de la API V2 de GoHighLevel (LeadConnector).
# Copia este archivo a .env y rellena los valores reales. NO commitees .env.

# Private Integration token de la subcuenta (empieza con "pit-...").
GHL_TOKEN=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Id de la subcuenta (location) sobre la que operas.
GHL_LOCATION_ID=xxxxxxxxxxxxxxxxxxxxxxxx

# Opcionales (tienen defaults en core/config.py):
# GHL_BASE_URL=https://services.leadconnectorhq.com
# GHL_API_VERSION=2021-04-15
